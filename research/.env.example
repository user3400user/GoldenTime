# Copy this file to .env and fill in your keys:  cp .env.example .env
# .env is gitignored — NEVER commit real keys.
#
# The environment runs WITHOUT keys using the built-in WebSearch + WebFetch tools.
# Adding these keys enables the Tavily and Firecrawl MCP servers and raises research quality.
#
# Claude Code expands ${VAR} in .mcp.json from its environment, and does NOT auto-load .env.
# So load the file before launching, e.g.:   set -a; source .env; set +a; claude

# Tavily — search / discovery + extraction with relevance scoring and domain filters
# Get a key: https://app.tavily.com
TAVILY_API_KEY=

# Firecrawl — deep scrape, crawl, and structured extraction of defined sources
# Get a key: https://www.firecrawl.dev
FIRECRAWL_API_KEY=
